# Comma-separated lowercase profile keys. Existing unsuffixed SN_* variables
# remain the fallback for the default profile.
SN_PROFILES=pdi,varenergi_dev
SN_DEFAULT_PROFILE=pdi

# Existing/default PDI profile (legacy names remain supported).
SN_INSTANCE=https://dev000000.service-now.com
SN_USERNAME=admin
SN_PASSWORD=replace-in-netlify-only
SN_WRITE_ENABLED=false
SN_DELETE_ENABLED=false
SN_WRITE_TABLES=
SN_DELETE_TABLES=
SN_ADDITIONAL_BLOCKED_TABLES=

# Additional instance profile. Profile keys become uppercase env prefixes.
SN_VARENERGI_DEV_LABEL=Var Energi DEV
SN_VARENERGI_DEV_INSTANCE=https://varenergidev.service-now.com
SN_VARENERGI_DEV_USERNAME=dedicated-api-admin
SN_VARENERGI_DEV_PASSWORD=replace-in-netlify-only
SN_VARENERGI_DEV_WRITE_ENABLED=true
SN_VARENERGI_DEV_DELETE_ENABLED=false
SN_VARENERGI_DEV_WRITE_TABLES=*
SN_VARENERGI_DEV_DELETE_TABLES=
SN_VARENERGI_DEV_ADDITIONAL_BLOCKED_TABLES=

MCP_OWNER_PASSWORD=replace-with-a-long-unique-password
MCP_TOKEN_PEPPER=replace-with-at-least-32-random-bytes
